#include <windows.h>
#include "../src/resource.h"

IDI_GRAY  ICON "gray.ico"
IDI_GREEN ICON "green.ico"
IDB_LOGO  BITMAP "hddsynthlogo.bmp"

// Context-menu item icons (src/tray.cpp, via SetMenuItemBitmaps) --
// see tools/make_menu_icons.py for how these are generated.
IDB_MENU_SAMPLE        BITMAP "menu_sample.bmp"
IDB_MENU_SETTINGS      BITMAP "menu_settings.bmp"
IDB_MENU_ABOUT         BITMAP "menu_about.bmp"
IDB_MENU_AUTOSTART_ON  BITMAP "menu_autostart_on.bmp"
IDB_MENU_AUTOSTART_OFF BITMAP "menu_autostart_off.bmp"
IDB_MENU_EXIT          BITMAP "menu_exit.bmp"

// Resource type 24 = RT_MANIFEST, ID 1 = CREATEPROCESS_MANIFEST_RESOURCE_ID
// (used as raw numbers rather than the symbolic names since those aren't
// guaranteed available at .rc preprocessing time). Enables XP visual
// styles (themed common controls) via the Microsoft.Windows.Common-
// Controls v6 dependency declared in hddsynth.manifest. Harmless on
// Win9x, which doesn't process manifests at all -- shared between both
// build targets, no #ifdef needed.
1 24 "hddsynth.manifest"

IDD_ABOUT DIALOG 0, 0, 220, 196
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About HDD Synth Win32"
FONT 8, "MS Sans Serif"
BEGIN
    CONTROL   "", IDC_ABOUT_LOGO, "STATIC", SS_BITMAP, 50, 8, 110, 76
    CTEXT     "HDD Synth Win32", IDC_ABOUT_APPNAME, 10, 88, 200, 10
    CTEXT     "", IDC_ABOUT_VERSION, 10, 100, 200, 10
    CTEXT     "", IDC_ABOUT_BUILD, 10, 112, 200, 10
    CTEXT     "", IDC_ABOUT_AUDIOAPI, 10, 124, 200, 10
    CTEXT     "By Peter Bridger", IDC_ABOUT_AUTHOR, 10, 136, 200, 10
    CTEXT     "", IDC_ABOUT_LINK, 10, 148, 200, 10, SS_NOTIFY
    DEFPUSHBUTTON "OK", IDOK, 85, 169, 50, 14
END

IDD_SETTINGS DIALOG 0, 0, 460, 212
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "HDD Synth Settings"
FONT 8, "MS Sans Serif"
BEGIN
    // Two-column layout: left column is Playback (top) + Disk Activity
    // (bottom), right column is Audio Engine (top) + Diagnostics
    // (bottom) -- wider and considerably shorter than the single stacked
    // column this used to be. Right column's x values are the left
    // column's plus 230 (column width 220 + 10 gap).

    GROUPBOX  "Playback", -1, 5, 5, 220, 90
    LTEXT     "Volume", -1, 10, 17, 60, 10
    CONTROL   "", IDC_VOLUME_SLIDER, "msctls_trackbar32", 0x00000001, 10, 29, 150, 15
    LTEXT     "", IDC_VOLUME_LABEL, 165, 31, 45, 10

    LTEXT     "Balance", -1, 10, 51, 60, 10
    CONTROL   "", IDC_BALANCE_SLIDER, "msctls_trackbar32", 0x00000001, 10, 63, 150, 15
    LTEXT     "", IDC_BALANCE_LABEL, 165, 65, 45, 10
    LTEXT     "Idle", -1, 10, 79, 30, 10
    RTEXT     "Activity", -1, 120, 79, 40, 10

    GROUPBOX  "Audio Engine", -1, 235, 5, 220, 90
    LTEXT     "Audio buffering", -1, 240, 17, 80, 10
    CONTROL   "", IDC_BUFFER_SLIDER, "msctls_trackbar32", 0x00000001, 240, 29, 150, 15
    LTEXT     "", IDC_BUFFER_LABEL, 395, 31, 45, 10
    LTEXT     "Low lag", -1, 240, 45, 40, 10
    RTEXT     "Fewer dropouts", -1, 330, 45, 60, 10

    LTEXT     "Audio API", -1, 240, 61, 60, 10
    COMBOBOX  IDC_AUDIOAPI_COMBO, 310, 59, 140, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT     "", IDC_AUDIOAPI_STATUS, 240, 75, 210, 10

    GROUPBOX  "Disk Activity", -1, 5, 103, 220, 75
    LTEXT     "Minimum access playback", -1, 10, 115, 110, 10
    CONTROL   "", IDC_MINPLAY_SLIDER, "msctls_trackbar32", 0x00000001, 10, 127, 150, 15
    LTEXT     "", IDC_MINPLAY_LABEL, 165, 129, 45, 10

    LTEXT     "Activity threshold (bytes/poll)", -1, 10, 145, 150, 10
    CONTROL   "", IDC_THRESHOLD_SLIDER, "msctls_trackbar32", 0x00000001, 10, 157, 150, 15
    LTEXT     "", IDC_THRESHOLD_LABEL, 165, 159, 45, 10

    GROUPBOX  "Diagnostics", -1, 235, 103, 220, 75
    LTEXT     "", IDC_LATENCY_LABEL, 250, 135, 100, 10
    LTEXT     "", IDC_UNDERRUN_LABEL, 360, 135, 100, 10

    PUSHBUTTON    "Help", IDC_HELP_BUTTON, 115, 188, 50, 14
    DEFPUSHBUTTON "OK", IDOK, 170, 188, 50, 14
    PUSHBUTTON    "Cancel", IDCANCEL, 225, 188, 50, 14
    PUSHBUTTON    "Apply", IDC_APPLY_BUTTON, 280, 188, 50, 14
END
