#include <windows.h>
#include "../src/resource.h"

IDI_GRAY  ICON "gray.ico"
IDI_GREEN ICON "green.ico"
IDB_LOGO  BITMAP "hddsynthlogo.bmp"

// Context-menu item icons (src/tray.cpp, via SetMenuItemBitmaps) --
// see tools/make_menu_icons.py for how these are generated.
IDB_MENU_SAMPLE   BITMAP "menu_sample.bmp"
IDB_MENU_SETTINGS BITMAP "menu_settings.bmp"
IDB_MENU_ABOUT    BITMAP "menu_about.bmp"
IDB_MENU_EXIT     BITMAP "menu_exit.bmp"

// Resource type 24 = RT_MANIFEST, ID 1 = CREATEPROCESS_MANIFEST_RESOURCE_ID
// (used as raw numbers rather than the symbolic names since those aren't
// guaranteed available at .rc preprocessing time). Enables XP visual
// styles (themed common controls) via the Microsoft.Windows.Common-
// Controls v6 dependency declared in hddsynth.manifest. Harmless on
// Win9x, which doesn't process manifests at all -- shared between both
// build targets, no #ifdef needed.
1 24 "hddsynth.manifest"

IDD_ABOUT DIALOG 0, 0, 220, 196
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About HDD Synth Win32"
FONT 8, "MS Sans Serif"
BEGIN
    CONTROL   "", IDC_ABOUT_LOGO, "STATIC", SS_BITMAP, 50, 8, 110, 76
    CTEXT     "HDD Synth Win32", IDC_ABOUT_APPNAME, 10, 88, 200, 10
    CTEXT     "", IDC_ABOUT_VERSION, 10, 100, 200, 10
    CTEXT     "", IDC_ABOUT_BUILD, 10, 112, 200, 10
    CTEXT     "", IDC_ABOUT_AUDIOAPI, 10, 124, 200, 10
    CTEXT     "By Peter Bridger", IDC_ABOUT_AUTHOR, 10, 136, 200, 10
    CTEXT     "", IDC_ABOUT_LINK, 10, 148, 200, 10, SS_NOTIFY
    DEFPUSHBUTTON "OK", IDOK, 85, 169, 50, 14
END

IDD_SETTINGS DIALOG 0, 0, 460, 222
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "HDD Synth Settings"
FONT 8, "MS Sans Serif"
BEGIN
    // Two-column layout: left column is Playback (top) + Disk Activity
    // (bottom), right column is Audio Engine (top) + Diagnostics
    // (bottom). Right column's x values are the left column's plus 230
    // (column width 220 + 10 gap). Every slider has an EDIT box beside it
    // (plus a unit suffix where one applies) so a value can be typed
    // directly instead of only ever dragged -- see settings_dialog.cpp's
    // SLIDER_EDITS table, which drives all of them generically. Playback
    // is taller than it used to be (three independent volume sliders
    // instead of one Volume + one Idle/Activity Balance slider), so Disk
    // Activity/Diagnostics below both shift down to match.

    GROUPBOX  "Playback", -1, 5, 5, 220, 100
    LTEXT     "Idle volume", -1, 10, 17, 90, 10
    CONTROL   "", IDC_IDLEVOL_SLIDER, "msctls_trackbar32", 0x00000001, 10, 29, 110, 15
    EDITTEXT  IDC_IDLEVOL_EDIT, 125, 30, 30, 13, ES_NUMBER | ES_RIGHT
    LTEXT     "%", -1, 158, 32, 10, 10

    LTEXT     "Activity volume", -1, 10, 45, 90, 10
    CONTROL   "", IDC_ACCESSVOL_SLIDER, "msctls_trackbar32", 0x00000001, 10, 57, 110, 15
    EDITTEXT  IDC_ACCESSVOL_EDIT, 125, 58, 30, 13, ES_NUMBER | ES_RIGHT
    LTEXT     "%", -1, 158, 60, 10, 10

    LTEXT     "Spin-up volume", -1, 10, 73, 90, 10
    CONTROL   "", IDC_SPINUPVOL_SLIDER, "msctls_trackbar32", 0x00000001, 10, 85, 110, 15
    EDITTEXT  IDC_SPINUPVOL_EDIT, 125, 86, 30, 13, ES_NUMBER | ES_RIGHT
    LTEXT     "%", -1, 158, 88, 10, 10

    GROUPBOX  "Audio Engine", -1, 235, 5, 220, 90
    LTEXT     "Audio buffering", -1, 240, 17, 80, 10
    CONTROL   "", IDC_BUFFER_SLIDER, "msctls_trackbar32", 0x00000001, 240, 29, 110, 15
    EDITTEXT  IDC_BUFFER_EDIT, 355, 30, 35, 13, ES_NUMBER | ES_RIGHT
    LTEXT     "ms", -1, 393, 32, 15, 10
    LTEXT     "Low lag", -1, 240, 45, 40, 10
    RTEXT     "Fewer dropouts", -1, 330, 45, 60, 10

    LTEXT     "Audio API", -1, 240, 61, 60, 10
    COMBOBOX  IDC_AUDIOAPI_COMBO, 310, 59, 140, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT     "", IDC_AUDIOAPI_STATUS, 240, 75, 210, 10

    GROUPBOX  "Disk Activity", -1, 5, 113, 220, 75
    LTEXT     "Minimum access playback", -1, 10, 125, 110, 10
    CONTROL   "", IDC_MINPLAY_SLIDER, "msctls_trackbar32", 0x00000001, 10, 137, 110, 15
    EDITTEXT  IDC_MINPLAY_EDIT, 125, 137, 30, 13, ES_NUMBER | ES_RIGHT
    LTEXT     "ms", -1, 158, 139, 15, 10

    LTEXT     "Activity threshold (bytes/poll)", -1, 10, 155, 150, 10
    CONTROL   "", IDC_THRESHOLD_SLIDER, "msctls_trackbar32", 0x00000001, 10, 167, 110, 15
    EDITTEXT  IDC_THRESHOLD_EDIT, 125, 167, 30, 13, ES_NUMBER | ES_RIGHT

    GROUPBOX  "Diagnostics", -1, 235, 113, 220, 75
    LTEXT     "", IDC_LATENCY_LABEL, 250, 145, 100, 10
    LTEXT     "", IDC_UNDERRUN_LABEL, 360, 145, 100, 10

    PUSHBUTTON    "Help", IDC_HELP_BUTTON, 115, 198, 50, 14
    DEFPUSHBUTTON "OK", IDOK, 170, 198, 50, 14
    PUSHBUTTON    "Cancel", IDCANCEL, 225, 198, 50, 14
    PUSHBUTTON    "Apply", IDC_APPLY_BUTTON, 280, 198, 50, 14
END
